.tooltip-container {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center
}

.tooltip {
    position: absolute;
    z-index: 1000;
    display: flex;
    align-items: center;
    padding: 0 8px 1px;
    height: 24px;
    background: rgba(68,68,68,.65);
    -webkit-backdrop-filter: blur(15px);
    backdrop-filter: blur(15px);
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    white-space: nowrap;
    font-family: Inter Variable,Inter,system-ui,sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: .01em;
    color: var(--color-white-85)
}

.tooltip--top {
    transform-origin: bottom center
}

.tooltip--bottom {
    transform-origin: top center
}

.tooltip--left {
    transform-origin: right center
}

.tooltip--right {
    transform-origin: left center
}

.tooltip--bottom.tooltip--animated,.tooltip--top.tooltip--animated {
    animation: tooltipEnterVertical .3s cubic-bezier(.19,1,.22,1) forwards
}

.tooltip--left.tooltip--animated,.tooltip--right.tooltip--animated {
    animation: tooltipEnterHorizontal .3s cubic-bezier(.19,1,.22,1) forwards
}

.tooltip--instant {
    opacity: 1;
    transform: scale(1)
}

@keyframes tooltipEnterVertical {
    0% {
        opacity: 0;
        transform: scale(.85)
    }

    to {
        opacity: 1;
        transform: scale(1)
    }
}

@keyframes tooltipEnterHorizontal {
    0% {
        opacity: 0;
        transform: scale(.85)
    }

    to {
        opacity: 1;
        transform: scale(1)
    }
}

.shortcut {
    margin-left: 12px;
    color: var(--color-white-50)
}
